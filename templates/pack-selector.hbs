<form class="scfc-pack-selector-form" autocomplete="off">
  <div class="form-group">
    <label>Search Packs</label>
    <input type="text" data-pack-search placeholder="Search by id, label, or module..." />
  </div>

  <div class="form-group scfc-action-row">
    <button type="button" data-pack-select-all>Select Visible</button>
    <button type="button" data-pack-clear-all>Clear Visible</button>
  </div>

  {{#if hasPacks}}
    <div class="form-group scfc-scroll-panel scfc-scroll-panel-packs">
      {{#each packs as |pack|}}
        <label class="scfc-list-row scfc-pack-row" data-pack-row data-search="{{pack.searchText}}">
          <span class="scfc-row-main">
            <input type="checkbox" name="packs" value="{{pack.id}}" {{#if pack.selected}}checked{{/if}} />
            <strong class="scfc-row-title">{{pack.label}}</strong>
            <span class="scfc-row-meta">{{pack.id}}</span>
          </span>
        </label>
      {{/each}}
    </div>
  {{else}}
    <p>No compendium packs are currently available.</p>
  {{/if}}

  <footer class="sheet-footer flexrow scfc-footer-row">
    <button type="submit">
      <i class="fas fa-save"></i>
      Save Selection
    </button>
  </footer>
</form>
