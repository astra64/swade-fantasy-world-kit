<form class="scfc-pack-selector-form" autocomplete="off">
  <div class="form-group">
    <label>Search Packs</label>
    <input type="text" data-pack-search placeholder="Search by id, label, or module..." />
  </div>

  <div class="form-group" style="display:flex; gap:0.5rem; margin-bottom:0.5rem;">
    <button type="button" data-pack-select-all>Select Visible</button>
    <button type="button" data-pack-clear-all>Clear Visible</button>
  </div>

  {{#if hasPacks}}
    <div class="form-group" style="max-height: 500px; overflow: auto; border: 1px solid var(--color-border-light-primary); padding: 0.5rem;">
      {{#each packs as |pack|}}
        <label data-pack-row data-search="{{pack.searchText}}" style="display:block; margin: 0.3rem 0;">
          <input type="checkbox" name="packs" value="{{pack.id}}" {{#if pack.selected}}checked{{/if}} />
          <strong>{{pack.label}}</strong>
          <span style="opacity: 0.7;">({{pack.id}})</span>
        </label>
      {{/each}}
    </div>
  {{else}}
    <p>No compendium packs are currently available.</p>
  {{/if}}

  <footer class="sheet-footer flexrow" style="margin-top: 0.75rem;">
    <button type="submit">
      <i class="fas fa-save"></i>
      Save Selection
    </button>
  </footer>
</form>
