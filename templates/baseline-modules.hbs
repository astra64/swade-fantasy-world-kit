<form class="scfc-baseline-modules-form" autocomplete="off" data-baseline-selection-signature="{{baselineSelectionSignature}}">
  <div class="scfc-flow-row" aria-label="Workflow overview">
    <div class="scfc-flow-step">
      <strong>Edit modules</strong>
      <span>Check or uncheck modules below.</span>
    </div>
    <div class="scfc-flow-step">
      <strong>Save when ready</strong>
      <span>Click Save to Preset to store the editing preset.</span>
    </div>
    <div class="scfc-flow-step">
      <strong>Apply to world</strong>
      <span>World modules do not change until you click Apply Preset.</span>
    </div>
  </div>

  <div class="scfc-active-preset-row" aria-label="Editing preset">
    <label class="scfc-active-preset-label" for="scfc-preset-selector">Editing Preset</label>
    <div class="scfc-active-preset-controls">
      <select id="scfc-preset-selector" class="scfc-preset-selector" data-preset-selector>
        {{#each presets as |preset|}}
          <option value="{{preset.id}}" {{#if preset.isActive}}selected{{/if}}>
            {{preset.name}} ({{preset.moduleCount}})
          </option>
        {{/each}}
      </select>
      <button type="button" class="scfc-preset-manage-btn" data-preset-manage title="Manage presets: create, rename, duplicate, delete">
        <i class="fas fa-cog"></i>
        <span>Manage Presets</span>
      </button>
    </div>
  </div>

  <div class="scfc-summary-row" aria-label="Preset summary">
    <span class="scfc-summary-chip" title="Total installed modules.">Installed: {{installedCount}}</span>
    <span class="scfc-summary-chip" title="Currently selected in this editing session.">Selected: {{selectedCount}}</span>
    <span class="scfc-summary-chip" title="Currently saved in the editing preset (may include uninstalled).">Saved: {{configuredCount}}</span>
    <span class="scfc-summary-chip {{#if isEditingPresetApplied}}scfc-summary-chip-good{{else}}scfc-summary-chip-warn{{/if}}" title="Last preset applied to this world in this module workflow.">Applied: {{appliedPresetName}}</span>
    <span class="scfc-summary-chip scfc-save-state-chip" data-baseline-save-state title="Matches = selection matches the editing preset.">Status: matches preset</span>
  </div>

  {{#if hasInstalledModules}}
    <div class="form-group scfc-scroll-panel scfc-scroll-panel-modules">
      <div class="scfc-panel-header">
        <div class="scfc-panel-header-left">
          <span class="scfc-panel-title">Installed Modules</span>
          <label class="scfc-panel-search" for="scfc-module-search">
            <input id="scfc-module-search" type="text" data-module-search aria-label="Search installed modules" placeholder="Search by title or ID..." />
          </label>
        </div>
        <span class="scfc-panel-header-actions">
          <button type="button" class="scfc-filter-toggle" data-module-select-active title="Check all active modules">Select Active</button>
          <button type="button" class="scfc-filter-toggle" data-module-clear-selection title="Uncheck all">Clear</button>
          <button type="button" class="scfc-filter-toggle" data-module-filter-active aria-pressed="false" title="Show active only">Active Only</button>
          <strong data-module-visible-count>{{installedCount}}</strong>
        </span>
      </div>
      {{#each installedModules as |entry|}}
        <label class="scfc-list-row" data-module-row data-search="{{entry.searchText}}" data-active="{{#if entry.active}}true{{else}}false{{/if}}" data-required="{{#if entry.required}}true{{else}}false{{/if}}">
          <span class="scfc-row-main">
            <input type="checkbox" name="baselineModulesSelected" value="{{entry.id}}" {{#if entry.selected}}checked{{/if}} {{#if entry.required}}checked disabled{{/if}} />
            <strong class="scfc-row-title">{{entry.title}}</strong>
            <span class="scfc-row-meta">{{entry.id}}</span>
          </span>
          <span>
            {{#if entry.missingInstalledDependencyCount}}
              <strong class="scfc-status-badge scfc-status-warning scfc-dep-indicator" title="Requires installed but inactive dependencies: {{entry.missingInstalledDependencyLabel}}">deps {{entry.missingInstalledDependencyCount}}</strong>
            {{/if}}
            {{#if entry.missingUninstalledDependencyCount}}
              <strong class="scfc-status-badge scfc-status-missing scfc-dep-indicator" title="Requires dependencies that are not installed: {{entry.missingUninstalledDependencyLabel}}">missing {{entry.missingUninstalledDependencyCount}}</strong>
            {{/if}}
            {{#if entry.required}}
              <strong class="scfc-status-badge">required</strong>
            {{/if}}
            {{#if entry.active}}
              <strong class="scfc-status-badge scfc-status-active">active</strong>
            {{/if}}
          </span>
        </label>
      {{/each}}
    </div>
  {{else}}
    <p>No installed modules were found.</p>
  {{/if}}

  {{#if hasConfigured}}
    <details class="scfc-configured-collapsible">
      <summary class="scfc-configured-summary">
        <span>Preset Contents</span>
        <strong>{{configuredCount}} total</strong>
      </summary>
      <p class="notes scfc-saved-baseline-notes">Shows what is stored in the editing preset. May include uninstalled modules.</p>
      <div class="scfc-scroll-panel scfc-scroll-panel-configured">
        {{#each configured as |entry|}}
          <div class="scfc-list-row" {{#unless entry.installed}}title="'{{entry.id}}' is saved in your editing preset but is not installed in this Foundry instance. To fix this: install the module via the Add-on Modules tab."{{/unless}}>
            <span class="scfc-configured-entry-main">
              {{#if entry.title}}
                <strong class="scfc-row-title">{{entry.title}}</strong>
              {{/if}}
              <code class="scfc-row-meta">{{entry.id}}</code>
            </span>
            <span class="scfc-configured-entry-state">
              {{#if entry.installed}}
                {{#if entry.active}}
                  <strong class="scfc-status-badge scfc-status-active">installed + active</strong>
                {{else}}
                  <strong class="scfc-status-badge">installed</strong>
                {{/if}}
              {{else}}
                <strong class="scfc-status-badge scfc-status-missing">missing</strong>
              {{/if}}
            </span>
          </div>
        {{/each}}
      </div>
    </details>
  {{else}}
    <p>No preset module IDs configured.</p>
  {{/if}}

  <p class="scfc-selection-delta" data-selection-delta title="Changes since last save.">No changes</p>

  <footer class="sheet-footer flexrow scfc-footer-row">
    <button type="submit" title="Save checked modules to the editing preset (does not enable them).">
      <i class="fas fa-save"></i>
      Save to Preset
    </button>
    <button type="button" data-revert-preset title="Reset checkboxes to the editing preset snapshot.">
      <i class="fas fa-undo"></i>
      Revert to Preset
    </button>
    <button type="button" data-apply-baseline title="Enable modules from the editing preset and reload world.">
      <i class="fas fa-check"></i>
      Apply Preset to World
    </button>
  </footer>
</form>
