<form class="scfc-baseline-modules-form" autocomplete="off">
  <div class="form-group scfc-search-group">
    <label>Search Installed Modules</label>
    <input type="text" data-module-search placeholder="Search by title or ID..." />
    <p class="notes scfc-search-notes">Select modules to include in your baseline profile for this world.</p>
  </div>

  <div class="form-group scfc-toolbar-row" aria-label="Baseline actions">
    <button type="button" data-module-select-active title="Check all modules that are currently active in this world">Select Active</button>
    <button type="button" data-module-clear-selection title="Uncheck all modules in the list">Clear Selection</button>
    <button type="button" data-module-load-global title="Replace the current selection with the saved Global Profile">Load Global</button>
    <button type="button" data-module-save-global title="Save the current selection as the Global Profile (shared across worlds)">Save Global</button>
    <button type="button" data-module-apply-global title="Enable all modules in the Global Profile in this world and reload">Apply Global</button>
  </div>

  <div class="scfc-summary-row" aria-label="Baseline summary">
    <span class="scfc-summary-chip">Installed: {{installedCount}}</span>
    <span class="scfc-summary-chip">Selected: {{selectedCount}}</span>
    <span class="scfc-summary-chip">Baseline entries: {{configuredCount}}</span>
  </div>

  {{#if hasInstalledModules}}
    <div class="form-group scfc-scroll-panel scfc-scroll-panel-modules">
      <div class="scfc-panel-header">
        <span>Installed modules</span>
        <span class="scfc-panel-header-actions">
          <button type="button" class="scfc-filter-toggle" data-module-filter-active aria-pressed="false" title="Show only modules that are currently active in this world">Active Only</button>
          <strong data-module-visible-count>{{installedCount}}</strong>
        </span>
      </div>
      {{#each installedModules as |entry|}}
        <label class="scfc-list-row" data-module-row data-search="{{entry.searchText}}" data-active="{{#if entry.active}}true{{else}}false{{/if}}" data-required="{{#if entry.required}}true{{else}}false{{/if}}">
          <span class="scfc-row-main">
            <input type="checkbox" name="baselineModulesSelected" value="{{entry.id}}" {{#if entry.selected}}checked{{/if}} {{#if entry.required}}checked disabled{{/if}} />
            <strong class="scfc-row-title">{{entry.title}}</strong>
            <span class="scfc-row-meta">{{entry.id}}</span>
          </span>
          <span>
            {{#if entry.missingInstalledDependencyCount}}
              <strong class="scfc-status-badge scfc-status-warning scfc-dep-indicator" title="Requires installed but inactive dependencies: {{entry.missingInstalledDependencyLabel}}">deps {{entry.missingInstalledDependencyCount}}</strong>
            {{/if}}
            {{#if entry.missingUninstalledDependencyCount}}
              <strong class="scfc-status-badge scfc-status-missing scfc-dep-indicator" title="Requires dependencies that are not installed: {{entry.missingUninstalledDependencyLabel}}">missing {{entry.missingUninstalledDependencyCount}}</strong>
            {{/if}}
            {{#if entry.required}}
              <strong class="scfc-status-badge">required</strong>
            {{/if}}
            {{#if entry.active}}
              <strong class="scfc-status-badge scfc-status-active">active</strong>
            {{/if}}
          </span>
        </label>
      {{/each}}
    </div>
  {{else}}
    <p>No installed modules were found.</p>
  {{/if}}

  {{#if hasConfigured}}
    <details class="scfc-configured-collapsible">
      <summary class="scfc-configured-summary">
        <span>Current baseline entries</span>
        <strong>{{configuredCount}} total</strong>
      </summary>
      <div class="scfc-scroll-panel scfc-scroll-panel-configured">
        {{#each configured as |entry|}}
          <div class="scfc-list-row" {{#unless entry.installed}}title="'{{entry.id}}' is saved in your baseline but is not installed in this Foundry instance. To fix this: install the module via the Add-on Modules tab, or remove it from your baseline by clicking the × button."{{/unless}}>
            <span>
              {{#if entry.title}}
                <strong class="scfc-row-title">{{entry.title}}</strong>
              {{/if}}
              <code class="scfc-row-meta">{{entry.id}}</code>
            </span>
            <span class="scfc-configured-entry-actions">
              {{#if entry.installed}}
                {{#if entry.active}}
                  <strong class="scfc-status-badge scfc-status-active">installed + active</strong>
                {{else}}
                  <strong class="scfc-status-badge">installed</strong>
                {{/if}}
              {{else}}
                <strong class="scfc-status-badge scfc-status-missing">missing</strong>
              {{/if}}
              <button type="button" class="scfc-remove-configured" data-remove-configured="{{entry.id}}" title="Remove '{{#if entry.title}}{{entry.title}}{{else}}{{entry.id}}{{/if}}' from baseline">×</button>
            </span>
          </div>
        {{/each}}
      </div>
    </details>
  {{else}}
    <p>No baseline module IDs configured.</p>
  {{/if}}

  <footer class="sheet-footer flexrow scfc-footer-row">
    <button type="submit" title="Save the checked modules as the baseline list for this world (does not enable them)">
      <i class="fas fa-save"></i>
      Save Selection
    </button>
    <button type="button" data-apply-baseline title="Enable all saved baseline modules in this world and reload">
      <i class="fas fa-check"></i>
      Apply Baseline to World
    </button>
  </footer>
</form>
